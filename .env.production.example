# ===========================================
# VINA IVAS - PRODUCTION ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.production and fill in real values
# NEVER commit .env.production to git!

# Admin Authentication
ADMIN_PASSWORD_HASH=  # Generate with: npx ts-node scripts/hash-password.ts YOUR_PASSWORD
JWT_SECRET=           # Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=kontakt@vina-ivas.hr
SMTP_PASS=  # Your Gmail app password (not your main password)

# Stripe (PRODUCTION KEYS - NOT TEST!)
STRIPE_SECRET_KEY=sk_live_            # Get from Stripe Dashboard
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_  # Get from Stripe Dashboard
STRIPE_WEBHOOK_SECRET=whsec_          # Get after setting up webhook endpoint

# Node Environment
NODE_ENV=production
